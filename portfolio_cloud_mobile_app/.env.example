# cloud 기본값은 supabase입니다.
DATABASE_BACKEND=supabase

# 로컬 SQLite 테스트 시에만 사용
SQLITE_DB_PATH=data/portfolio.db

# Supabase PostgreSQL 사용 시 Streamlit secrets 또는 OS 환경변수에 설정하세요.
DATABASE_URL=
SUPABASE_POOLER_DATABASE_URL=
SUPABASE_DIRECT_DATABASE_URL=
SUPABASE_PROJECT_URL=

# App access gate. Use Streamlit Secrets in production.
APP_AUTH_REQUIRED=true
APP_PASSWORD=
# APP_PASSWORD_SHA256=

# API Keys
OPENAI_API_KEY=
OPENDART_API_KEY=
SEC_USER_AGENT=Personal Portfolio Disclosure Tracker your_email@example.com
